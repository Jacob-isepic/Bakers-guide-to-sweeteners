<!DOCTYPE html>
<html>
<head>
  <title>Allulose</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<h2>🍯 Allulose Tool</h2>

<div class="card">
<p>Replace sugar while keeping baking structure.</p>
</div>

<input id="sugar" type="number" placeholder="Sugar (g)">
<input id="pct" type="number" placeholder="Replacement %">

<button onclick="calc()">Calculate</button>

<div id="result"></div>

<script>
function calc() {
  let sugar = Number(document.getElementById("sugar").value);
  let pct = Number(document.getElementById("pct").value) / 100;

  let kept = sugar * (1 - pct);
  let allulose = (sugar * pct) / 0.7;

  document.getElementById("result").innerHTML =
    "🥄 Sugar kept: " + kept.toFixed(1) + "g\n" +
    "🍯 Allulose: " + allulose.toFixed(1) + "g";
}
</script>

</body>
</html>