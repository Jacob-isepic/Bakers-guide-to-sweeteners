<!DOCTYPE html>
<html>
<head>
  <title>Monk Fruit Tool</title>
  <link rel="stylesheet" href="style.css">
</head>

<body>

<h2>🍬 Monk Fruit Converter</h2>

<p>Enter sugar amount → get monk fruit equivalent.<br>
Use this for pure extract (not 1:1 blends).</p>

<input id="sugar" type="number" placeholder="Sugar (g)">
<input id="factor" type="number" value="200">

<button onclick="calc()">Convert</button>

<div id="result"></div>

<script>
function calc() {
  let sugar = Number(document.getElementById("sugar").value);
  let factor = Number(document.getElementById("factor").value);

  let monk = sugar / factor;

  document.getElementById("result").innerHTML =
    "✨ Monk fruit needed: " + monk.toFixed(3) + "g";
}
</script>

</body>
</html>