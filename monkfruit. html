<!DOCTYPE html>
<html>
<head>
  <title>Monk Fruit</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<h2>🍬 Monk Fruit Tool</h2>

<div class="card">
<p>Enter sugar → convert to pure monk fruit extract.</p>
</div>

<input id="sugar" type="number" placeholder="Sugar (g)">
<input id="factor" type="number" value="200">

<button onclick="calc()">Convert</button>

<div id="result"></div>

<script>
function calc() {
  let sugar = Number(document.getElementById("sugar").value);
  let factor = Number(document.getElementById("factor").value);

  let result = sugar / factor;

  document.getElementById("result").innerHTML =
    "🍬 Monk fruit needed: " + result.toFixed(4) + "g";
}
</script>

</body>
</html>