body {
  font-family: Arial;
  max-width: 600px;
  margin: auto;
  padding: 20px;
  background: #f6f6f6;
  text-align: center;
}

.menu {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.card {
  background: white;
  padding: 15px;
  border-radius: 12px;
  text-decoration: none;
  color: black;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.card p {
  font-size: 12px;
  color: gray;
}