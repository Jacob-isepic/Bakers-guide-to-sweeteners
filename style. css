body {
  font-family: Arial, sans-serif;
  max-width: 600px;
  margin: auto;
  padding: 18px;
  background: #f5f6f8;
}

h1, h2 {
  text-align: center;
}

.card {
  background: white;
  padding: 14px;
  border-radius: 14px;
  margin: 12px 0;
  box-shadow: 0 3px 10px rgba(0,0,0,0.08);
}

a.card {
  display: block;
  text-decoration: none;
  color: black;
}

input, select {
  width: 100%;
  padding: 10px;
  margin: 6px 0 12px;
  border-radius: 10px;
  border: 1px solid #ccc;
}

button {
  width: 100%;
  padding: 12px;
  border: none;
  border-radius: 12px;
  background: black;
  color: white;
  font-size: 16px;
}

#result {
  margin-top: 14px;
  padding: 14px;
  background: white;
  border-radius: 12px;
  white-space: pre-line;
}